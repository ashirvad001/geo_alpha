# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=stockadmin
POSTGRES_PASSWORD=stockpass123
POSTGRES_DB=stockintel

# ─── MongoDB ──────────────────────────────────────────
MONGO_USER=mongoadmin
MONGO_PASSWORD=mongopass123

# ─── Connection URLs (overridden in docker-compose) ──
DATABASE_URL=postgresql+asyncpg://stockadmin:stockpass123@localhost:5432/stockintel
MONGO_URL=mongodb://mongoadmin:mongopass123@localhost:27017
REDIS_URL=redis://localhost:6379/0

# ─── Scraper Settings ────────────────────────────────
NSE_RATE_LIMIT=5
SCRAPER_MAX_RETRIES=3

# ─── RBI Settings ────────────────────────────────────
RBI_BULLETIN_URL=https://www.rbi.org.in/Scripts/BS_ViewBulletin.aspx
